{
  "manifest_version": 3,
  "name": "HPBブログ自動投稿",
  "version": "1.0.0",
  "description": "ホットペッパービューティーのサロンブログにSupabaseの予約記事を自動投稿する",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "https://salon.hotpepper.jp/*",
    "https://beauty.hotpepper.jp/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HPBブログ自動投稿"
  },
  "content_scripts": [
    {
      "matches": ["https://salon.hotpepper.jp/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
